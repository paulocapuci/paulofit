const calcMacros = (fav, qty) => {
if (!qty || qty <= 0) return null;
if (fav.unit === “un”) {
const p = fav.perUnit;
return { kcal:p.kcal*qty, prot:p.prot*qty, carbo:p.carbo*qty, gord:p.gord*qty };
}
const r = qty/100, p = fav.per100;
return { kcal:p.kcal*r, prot:p.prot*r, carbo:p.carbo*r, gord:p.gord*r };
};

