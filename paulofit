      {id:"home",label:"Início",icon:<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>},
      {id:"stats",label:"Stats",icon:<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>},
    ].map(n=>(
      <button key={n.id} className={`ni${tab===n.id?" a":""}`} onClick={()=>setTab(n.id)}>
        {n.icon}{n.label}
      </button>
    ))}
  </nav>

  {/* MODAL ADD */}
  {modal==="add" && (
    <div style={{position:"fixed",inset:0,background:"rgba(0,0,0,0.9)",backdropFilter:"blur(8px)",zIndex:100,display:"flex",alignItems:"flex-end",justifyContent:"center"}}
      onClick={e=>{if(e.target===e.currentTarget)setModal(null);}}>
      <div style={{background:"#131313",border:`1px solid ${C.b2}`,borderRadius:"20px 20px 0 0",width:"100%",maxWidth:480,padding:"16px 14px 28px",maxHeight:"88vh",overflowY:"auto"}}>
        <div style={{width:30,height:3,background:C.b2,borderRadius:99,margin:"0 auto 14px"}}/>
        <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:12}}>
          <div style={{fontFamily:"'Barlow Condensed',sans-serif",fontSize:"1.2rem",fontWeight:800,textTransform:"uppercase",letterSpacing:1}}>Adicionar Alimento</div>
          <button onClick={()=>setModal(null)} style={{background:"none",border:"none",color:C.t2,fontSize:"1.1rem",cursor:"pointer"}}>✕</button>
        </div>
        <div style={{fontSize:"0.58rem",textTransform:"uppercase",letterSpacing:1.5,color:C.t2,marginBottom:5}}>Refeição</div>
        <div style={{display:"flex",gap:5,flexWrap:"wrap",marginBottom:12}}>
          {MEALS.map(m=>(
            <button key={m} className={`mc${selMeal===m?" a":""}`} onClick={()=>setSelMeal(m)}>{m}</button>
          ))}
        </div>
        <div style={{fontSize:"0.58rem",textTransform:"uppercase",letterSpacing:1.5,color:C.t2,marginBottom:5}}>Favoritos</div>
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:5,marginBottom:12}}>
          {FAVORITES.map(f=>(
            <div key={f.id} className={`fc${selFav?.id===f.id?" s":""}`} onClick={()=>{setSelFav(f);setQty("");}}>
              <div style={{fontSize:"1.1rem",marginBottom:2}}>{f.emoji}</div>
              <div style={{fontSize:"0.72rem",fontWeight:600,lineHeight:1.2}}>{f.name}</div>
              <div style={{fontSize:"0.55rem",color:C.t2,marginTop:2}}>
                {f.unit==="un"?`${f.perUnit.kcal}kcal/un`:`${f.per100.kcal}kcal/100g`}
              </div>
            </div>
          ))}
        </div>
        {selFav && (
          <div>
            <div style={{fontSize:"0.58rem",textTransform:"uppercase",letterSpacing:1.5,color:C.t2,marginBottom:5}}>
              {selFav.emoji} {selFav.name} — quantidade
            </div>
            <div style={{display:"flex",gap:8,alignItems:"center",marginBottom:8}}>
              <input className="gin" type="number" placeholder="0" value={qty} onChange={e=>setQty(e.target.value)} autoFocus/>
              <span style={{fontFamily:"'Barlow Condensed',sans-serif",fontSize:"1rem",color:C.t2}}>{selFav.unit==="un"?"un":"g"}</span>
            </div>
            {preview && (
              <div style={{background:C.s2,border:`1px solid ${C.b1}`,borderRadius:10,padding:"9px 12px",display:"flex",justifyContent:"space-around",marginBottom:2}}>
                {[{v:preview.kcal,l:"kcal",c:C.lime},{v:preview.prot+"g",l:"prot",c:C.blue},{v:preview.carbo+"g",l:"carbo",c:C.orange},{v:preview.gord+"g",l:"gord",c:C.pink}].map(p=>(
                  <div key={p.l} style={{textAlign:"center"}}>
                    <div style={{fontFamily:"'Barlow Condensed',sans-serif",fontSize:"1rem",fontWeight:700,color:p.c,lineHeight:1}}>{p.v}</div>
                    <div style={{fontSize:"0.52rem",color:C.t2,textTransform:"uppercase",marginTop:2}}>{p.l}</div>
                  </div>
                ))}
              </div>
            )}
            <button className="cb" disabled={!qty||parseFloat(qty)<=0} onClick={addFood}>Adicionar</button>
          </div>
        )}
      </div>
    </div>
  )}

  {/* MODAL DAY */}
  {modal==="day" && (
    <div style={{position:"fixed",inset:0,background:"rgba(0,0,0,0.9)",backdropFilter:"blur(8px)",zIndex:100,display:"flex",alignItems:"flex-end",justifyContent:"center"}}
      onClick={e=>{if(e.target===e.currentTarget)setModal(null);}}>
      <div style={{background:"#131313",border:`1px solid ${C.b2}`,borderRadius:"20px 20px 0 0",width:"100%",maxWidth:480,padding:"16px 14px 28px"}}>
        <div style={{width:30,height:3,background:C.b2,borderRadius:99,margin:"0 auto 14px"}}/>
        <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:14}}>
          <div style={{fontFamily:"'Barlow Condensed',sans-serif",fontSize:"1.2rem",fontWeight:800,textTransform:"uppercase",letterSpacing:1}}>Tipo de Dia</div>
          <button onClick={()=>setModal(null)} style={{background:"none",border:"none",color:C.t2,fontSize:"1.1rem",cursor:"pointer"}}>✕</button>
        </div>
        {[{t:"rest",e:"😴",ti:"Dia de Descanso",s:"Meta: 1.780 kcal · ~130g proteína"},{t:"workout",e:"💪",ti:"Dia de Treino",s:"Meta: 1.780 kcal · ~180g proteína"}].map(o=>(
          <div key={o.t} className={`do${tempDay===o.t?" s":""}`} onClick={()=>setTempDay(o.t)}>
            <div style={{fontSize:"1.4rem"}}>{o.e}</div>
            <div><div style={{fontWeight:700,fontSize:"0.85rem"}}>{o.ti}</div><div style={{fontSize:"0.62rem",color:C.t2,marginTop:2}}>{o.s}</div></div>
          </div>
        ))}
        {tempDay==="workout" && (
          <>
            <div style={{fontSize:"0.58rem",textTransform:"uppercase",letterSpacing:1.5,color:C.t2,margin:"10px 0 6px"}}>Tipo de treino</div>
            <div style={{display:"flex",gap:6,flexWrap:"wrap"}}>
              {["Musculação","Cardio","Musculação + Cardio"].map(w=>(
                <button key={w} className={`wc${tempWo===w?" a":""}`} onClick={()=>setTempWo(w)}>
                  {w==="Musculação"?"🏋️ Musculação":w==="Cardio"?"🏃 Cardio":"⚡ Ambos"}
                </button>
              ))}
            </div>
          </>
        )}
        <button className="cb" onClick={confirmDay}>Confirmar</button>
      </div>
    </div>
  )}

  {/* TOAST */}
  <div style={{position:"fixed",bottom:80,left:"50%",transform:`translateX(-50%) translateY(${toast.show?0:8}px)`,background:"#1e1e1e",border:`1px solid ${C.b2}`,borderRadius:99,padding:"7px 16px",fontSize:"0.72rem",fontWeight:600,whiteSpace:"nowrap",opacity:toast.show?1:0,transition:"all 0.3s cubic-bezier(0.16,1,0.3,1)",zIndex:200,pointerEvents:"none"}}>
    {toast.msg}
  </div>
</div>
